# Sprucelab test env — copy to .env.test for local pytest runs.
#
# CRITICAL: every host MUST be localhost. The conftest's safety check
# refuses to run if DATABASE_URL points anywhere else.

DEBUG=True
SECRET_KEY=test-secret-not-for-production
ALLOWED_HOSTS=localhost,127.0.0.1,testserver

# Local Postgres (matches docker-compose.dev.yml). pytest-django will
# create test_sprucelab_dev automatically.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sprucelab_dev

REDIS_URL=redis://localhost:6379/2
CELERY_BROKER_URL=redis://localhost:6379/2

DJANGO_URL=http://localhost:8000
IFC_SERVICE_URL=http://127.0.0.1:8001
IFC_SERVICE_API_KEY=test-key
