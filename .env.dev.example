# Local Development Environment
# Copy to .env.dev: cp .env.dev.example .env.dev
# Used by ./dev.sh - points to local PostgreSQL + Redis
# No Supabase keys = local file storage in backend/media/

# Django
SECRET_KEY=dev-secret-key-not-for-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Local PostgreSQL (from docker-compose.dev.yml)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sprucelab_dev

# Redis
REDIS_URL=redis://localhost:6379/1
CELERY_BROKER_URL=redis://localhost:6379/0

# FastAPI IFC Service
IFC_SERVICE_URL=http://localhost:8001
IFC_SERVICE_API_KEY=dev-key

# Django base URL (for FastAPI callbacks)
DJANGO_URL=http://localhost:8000

# Dev-only auth bypass.
# When set + DEBUG=True, every API request authenticates as DEV_AUTH_BYPASS_EMAIL
# (auto-created superuser with approved profile). Refuses to fire if DEBUG=False
# so it cannot leak to a Railway prod deploy. Pair with frontend
# `VITE_DEV_AUTH_BYPASS=1` for the UI side (already set in frontend/.env.development).
DEV_AUTH_BYPASS=1
DEV_AUTH_BYPASS_EMAIL=dev@local.test
