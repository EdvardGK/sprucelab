{
  "buildCommand": "yarn build",
  "installCommand": "corepack enable && corepack prepare yarn@4.12.0 --activate && yarn install --immutable",
  "outputDirectory": "dist",
  "framework": "vite",
  "ignoreCommand": "git diff --quiet ${VERCEL_GIT_PREVIOUS_SHA:-HEAD^} HEAD -- .",
  "rewrites": [
    { "source": "/api/(.*)",                         "destination": "https://sprucelab-production.up.railway.app/api/$1" },
    { "source": "/llms.txt",                         "destination": "https://sprucelab-production.up.railway.app/llms.txt" },
    { "source": "/.well-known/agent-tools.json",     "destination": "https://sprucelab-production.up.railway.app/.well-known/agent-tools.json" },
    { "source": "/((?!api/|llms\\.txt|\\.well-known/).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, max-age=0, must-revalidate" },
        { "key": "CDN-Cache-Control", "value": "no-store" },
        { "key": "Vercel-CDN-Cache-Control", "value": "no-store" }
      ]
    },
    {
      "source": "/llms.txt",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, max-age=0, must-revalidate" },
        { "key": "CDN-Cache-Control", "value": "no-store" },
        { "key": "Vercel-CDN-Cache-Control", "value": "no-store" }
      ]
    },
    {
      "source": "/.well-known/agent-tools.json",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, max-age=0, must-revalidate" },
        { "key": "CDN-Cache-Control", "value": "no-store" },
        { "key": "Vercel-CDN-Cache-Control", "value": "no-store" }
      ]
    }
  ]
}
